{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "saas-ecommercw-ai",
    "main": ".open-next/worker.js",
    "compatibility_date": "2025-02-28",
    "compatibility_flags": [
      "nodejs_compat"
    ],
    "assets": {
      "directory": ".open-next/assets",
      "binding": "ASSETS"
    }
  }